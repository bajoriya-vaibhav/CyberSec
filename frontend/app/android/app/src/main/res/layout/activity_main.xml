<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="28dp">

        <!-- Logo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="🛡️"
            android:textSize="64sp" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="DeepGuard"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="Your ultimate defense against AI-generated media.\nDetect deepfakes in real-time streams or upload files for detailed analysis."
            android:textColor="#90FFFFFF"
            android:textSize="13sp" />

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  GLOBAL SETTINGS SECTION                               -->
        <!-- ═══════════════════════════════════════════════════════ -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚙️ Global Settings"
                android:textColor="#E0E0E0"
                android:textSize="14sp"
                android:textStyle="bold" />
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Configure the connection to your AI detection Server."
                android:textColor="#60FFFFFF"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/editServerUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/input_bg"
                android:hint="http://10.0.2.2:7860"
                android:textColorHint="#40FFFFFF"
                android:textColor="#F0F0F0"
                android:textSize="13sp"
                android:padding="12dp"
                android:singleLine="true"
                android:inputType="textUri"
                android:imeOptions="actionDone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Use '10.0.2.2' for Emulator, or Ngrok URL for physical device."
                android:textColor="#50FFFFFF"
                android:textSize="10sp" />

        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  REAL-TIME OVERLAY SECTION                             -->
        <!-- ═══════════════════════════════════════════════════════ -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📱 Live Overlay Mode"
                android:textColor="#E0E0E0"
                android:textSize="14sp"
                android:textStyle="bold" />
                
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="2dp"
                android:text="A floating window that active scans the screen while you watch videos on Instagram, YouTube, etc. Auto-starts when people appear."
                android:textColor="#60FFFFFF"
                android:textSize="11sp" />

            <!-- Analysis Duration Setting -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Buffer Duration"
                android:textColor="#B0FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtDurationValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="15 seconds"
                android:textColor="#4FC3F7"
                android:textSize="18sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/seekDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:min="3"
                android:max="30"
                android:progress="15"
                android:progressTint="#4FC3F7"
                android:thumbTint="#4FC3F7" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="3s"
                    android:textColor="#40FFFFFF"
                    android:textSize="10sp" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="30s"
                    android:textColor="#40FFFFFF"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Enable Overlay Button -->
            <Button
                android:id="@+id/btnStartOverlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:padding="14dp"
                android:backgroundTint="#2E7D32"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="14sp"
                android:text="ENABLE OVERLAY" />

        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  FILE ANALYSIS SECTION                                 -->
        <!-- ═══════════════════════════════════════════════════════ -->

        <!-- Upload card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔬 Deep File Analysis"
                android:textColor="#E0E0E0"
                android:textSize="14sp"
                android:textStyle="bold" />
                
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="12dp"
                android:lineSpacingExtra="2dp"
                android:text="Upload a specific video or image from your gallery for an in-depth forensic analysis. Results contribute to the global detection database if verified."
                android:textColor="#60FFFFFF"
                android:textSize="11sp" />

            <!-- Pick buttons row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btnPickImage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:backgroundTint="#1A4FC3F7"
                    android:text="[  IMAGE  ]"
                    android:textColor="#4FC3F7"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:padding="12dp" />

                <Button
                    android:id="@+id/btnPickVideo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:backgroundTint="#1A9C27B0"
                    android:text="[  VIDEO  ]"
                    android:textColor="#CE93D8"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:padding="12dp" />

            </LinearLayout>

            <!-- Selected file name -->
            <TextView
                android:id="@+id/txtSelectedFile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="No file selected"
                android:textColor="#50FFFFFF"
                android:textSize="11sp"
                android:gravity="center"
                android:singleLine="true"
                android:ellipsize="middle" />

            <!-- Analyse button -->
            <Button
                android:id="@+id/btnAnalyseFile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:backgroundTint="#37474F"
                android:text="ANALYSE"
                android:textColor="#90FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:enabled="false"
                android:padding="14dp" />

            <!-- Progress indicator -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="12dp"
                android:layout_gravity="center"
                android:indeterminateTint="#4FC3F7"
                android:visibility="gone" />

            <!-- Analysis status text -->
            <TextView
                android:id="@+id/txtAnalysisStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text=""
                android:textColor="#70FFFFFF"
                android:textSize="11sp"
                android:gravity="center"
                android:visibility="gone" />
                
            <!-- ════════ RESULT CARD ════════ -->
            <LinearLayout
                android:id="@+id/resultCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:background="#15FFFFFF"
                android:padding="16dp"
                android:visibility="gone">

                <!-- Verdict row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/txtVerdictEmoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✅"
                        android:textSize="36sp"
                        android:paddingEnd="16dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/txtVerdictLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="REAL"
                            android:textColor="#66BB6A"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtConfidence"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="87.3% confident"
                            android:textColor="#B0FFFFFF"
                            android:textSize="13sp" />

                    </LinearLayout>
                </LinearLayout>

                <!-- Detail row -->
                <TextView
                    android:id="@+id/txtResultDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="15 frames • 3200ms"
                    android:textColor="#50FFFFFF"
                    android:textSize="10sp"
                    android:gravity="center" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="10dp"
                    android:background="#20FFFFFF" />

                <!-- Verification label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Verify &amp; Add to Dataset:"
                    android:textColor="#70FFFFFF"
                    android:textSize="11sp"
                    android:layout_marginBottom="8dp" />

                <!-- Mark Real / Mark Fake buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnMarkReal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:backgroundTint="#1B5E20"
                        android:text="REAL"
                        android:textColor="#A5D6A7"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:padding="10dp" />

                    <Button
                        android:id="@+id/btnMarkFake"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:backgroundTint="#B71C1C"
                        android:text="FAKE"
                        android:textColor="#FFCDD2"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:padding="10dp" />

                </LinearLayout>

                <!-- Verification status -->
                <TextView
                    android:id="@+id/txtVerifyStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text=""
                    android:textColor="#70FFFFFF"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
