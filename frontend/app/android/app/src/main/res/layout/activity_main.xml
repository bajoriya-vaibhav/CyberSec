<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="28dp">

        <!-- Logo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:text="🛡️"
            android:textSize="72sp" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="DeepGuard"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Real-time deepfake detection"
            android:textColor="#80FFFFFF"
            android:textSize="14sp" />

        <!-- Server URL Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔗  Server URL"
                android:textColor="#E0E0E0"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editServerUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_bg"
                android:hint="http://10.0.2.2:7860"
                android:textColorHint="#40FFFFFF"
                android:textColor="#F0F0F0"
                android:textSize="13sp"
                android:padding="12dp"
                android:singleLine="true"
                android:inputType="textUri"
                android:imeOptions="actionDone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Use 10.0.2.2 for emulator, ngrok URL for physical device"
                android:textColor="#50FFFFFF"
                android:textSize="10sp" />

        </LinearLayout>

        <!-- Analysis Duration Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏱  Analysis Duration"
                android:textColor="#E0E0E0"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtDurationValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="15 seconds"
                android:textColor="#4FC3F7"
                android:textSize="20sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/seekDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:min="3"
                android:max="30"
                android:progress="15"
                android:progressTint="#4FC3F7"
                android:thumbTint="#4FC3F7" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="3s"
                    android:textColor="#40FFFFFF"
                    android:textSize="10sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="30s"
                    android:textColor="#40FFFFFF"
                    android:textSize="10sp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Longer = more frames = more accurate results"
                android:textColor="#50FFFFFF"
                android:textSize="10sp" />

        </LinearLayout>

        <!-- Enable Overlay Button -->
        <Button
            android:id="@+id/btnStartOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:padding="16dp"
            android:backgroundTint="#2E7D32"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="15sp"
            android:text="🛡️  Enable Overlay" />

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  FILE ANALYSIS SECTION                                 -->
        <!-- ═══════════════════════════════════════════════════════ -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="8dp"
            android:text="🔬  Analyse File"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Upload card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp">

            <!-- Pick buttons row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btnPickImage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:backgroundTint="#1A4FC3F7"
                    android:text="🖼 Image"
                    android:textColor="#4FC3F7"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:padding="12dp" />

                <Button
                    android:id="@+id/btnPickVideo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:backgroundTint="#1A9C27B0"
                    android:text="🎬 Video"
                    android:textColor="#CE93D8"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:padding="12dp" />

            </LinearLayout>

            <!-- Selected file name -->
            <TextView
                android:id="@+id/txtSelectedFile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="No file selected"
                android:textColor="#50FFFFFF"
                android:textSize="11sp"
                android:gravity="center"
                android:singleLine="true"
                android:ellipsize="middle" />

            <!-- Analyse button -->
            <Button
                android:id="@+id/btnAnalyseFile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:backgroundTint="#37474F"
                android:text="Analyse"
                android:textColor="#90FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:enabled="false"
                android:padding="14dp" />

            <!-- Analysis status / spinner text -->
            <TextView
                android:id="@+id/txtAnalysisStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text=""
                android:textColor="#70FFFFFF"
                android:textSize="11sp"
                android:gravity="center"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Result Card (hidden until result arrives) -->
        <LinearLayout
            android:id="@+id/resultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:visibility="gone">

            <!-- Verdict row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txtVerdictEmoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅"
                    android:textSize="42sp"
                    android:paddingEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtVerdictLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="REAL"
                        android:textColor="#66BB6A"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtConfidence"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="87.3% confident"
                        android:textColor="#B0FFFFFF"
                        android:textSize="13sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Detail row: frames + time -->
            <TextView
                android:id="@+id/txtResultDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="15 frames  •  3200ms"
                android:textColor="#50FFFFFF"
                android:textSize="10sp"
                android:gravity="center" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="10dp"
                android:background="#15FFFFFF" />

            <!-- Verification label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mark for dataset (optional):"
                android:textColor="#70FFFFFF"
                android:textSize="11sp"
                android:layout_marginBottom="8dp" />

            <!-- Mark Real / Fake -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnMarkReal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:backgroundTint="#1B5E20"
                    android:text="✅ Mark Real"
                    android:textColor="#A5D6A7"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:padding="12dp" />

                <Button
                    android:id="@+id/btnMarkFake"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:backgroundTint="#B71C1C"
                    android:text="🚨 Mark Fake"
                    android:textColor="#FFCDD2"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:padding="12dp" />

            </LinearLayout>

            <!-- Verification status message -->
            <TextView
                android:id="@+id/txtVerifyStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text=""
                android:textColor="#70FFFFFF"
                android:textSize="11sp"
                android:gravity="center"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Footer info text -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="Settings are saved automatically.\nUse the floating overlay to start/stop analysis."
            android:textColor="#50FFFFFF"
            android:textSize="11sp" />

    </LinearLayout>

</ScrollView>
